# Project base URL, for example https://your-project.supabase.co
# Do not append /rest/v1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_UMAMI_HOST_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_ENABLED=true

# Server-only dashboard access. Use either an Umami Cloud API key or a
# self-hosted bearer token. Never prefix these with NEXT_PUBLIC_.
UMAMI_API_URL=
UMAMI_API_KEY=
UMAMI_API_TOKEN=
